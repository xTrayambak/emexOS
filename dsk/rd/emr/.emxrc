var gui = 1 // the variable just needs to exist to work
//var ebl = 1

var lsblk       = ("/bin/lsblk.elf")
var stinf       = ("/emr/system/system.emx/stinf.elf")
var desktop     = ("/emr/system/desktop.elf")
var sysinfo     = ("/emr/system/sysinfo.elf")
var filemanager = ("/emr/system/fm.elf")
var bg_test     = ("/emr/system/sinfo.elf")
var bg_test2    = ("/emr/system/libraries/cursor.elf")
var login_path  = ("/emr/system/login.elf")
var gshell_path = (ep: "/emr/system/terminal.emx")
var shell_path  = (ep: "/emr/system/shell.emx")

print("succesfully jumped into userspace...")

if stinf
	print("stinf found... loading...")
	exec stinf
	//exec /emr/system/system.emx/initd.elf
	//exec /bin/meminfo.elf
else
	elog("warning: stinf not found")
endif

wait 3

if gui
	//print("gui variable found")
	exec -bg desktop
	//exec -bg bg_test
	//exec -bg bg_test

	exec login_path
	exec -bg sysinfo
	//exec -bg filemanager
	exec -f"ep" gshell_path
else
	//print("gui variable NOT found")
	exec shell_path
endif